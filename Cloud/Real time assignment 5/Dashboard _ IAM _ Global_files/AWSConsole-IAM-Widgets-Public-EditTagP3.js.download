s-new/2025/06/aws-resource-control-policies-additional-services\\", \\"postDateTime\\": \\"06/19/2025\\", \\"absoluteDateTime\\": \\"2025-06-19T13:00:00-04:00\\"}, \\"feature3\\": {\\"headline\\": \\"AWS IAM now enforces MFA for root users across all account types\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/aws-iam-mfa-root-users-across-all-account-types/\\", \\"postDateTime\\": \\"06/17/2025\\", \\"absoluteDateTime\\": \\"2025-06-17T10:00:00-04:00\\"}, \\"feature4\\": {\\"headline\\": \\"Amazon EKS Pod Identity simplifies the experience for cross-account access\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/amazon-eks-pod-identity-cross-account-access\\", \\"postDateTime\\": \\"06/12/2025\\", \\"absoluteDateTime\\": \\"2025-06-12T13:00:00-05:00\\"}, \\"feature5\\": {\\"headline\\": \\"Amazon EBS now supports additional resource-level permissions for copying EBS snapshots\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/04/amazon-ebs-additional-resource-level-permissions-copying-eb-snapshots\\", \\"postDateTime\\": \\"04/22/2025\\", \\"absoluteDateTime\\": \\"2025-04-22T15:15:00-04:00\\"}, \\"feature6\\": {\\"headline\\": \\"AWS Identity and Access Management now supports dual-stack (IPv4 and IPv6) environments\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/aws-identity-access-management-dual-stack-ipv4-ipv6-environments\\", \\"postDateTime\\": \\"03/28/2025\\", \\"absoluteDateTime\\": \\"2025-03-28T16:40:00-04:00\\"}, \\"feature7\\": {\\"headline\\": \\"AWS Service Reference Information now supports resources and condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/aws-service-reference-information-resources-condition-keys\\", \\"postDateTime\\": \\"03/13/2025\\", \\"absoluteDateTime\\": \\"2025-03-13T13:00:00-04:00\\"}, \\"feature8\\": {\\"headline\\": \\"IAM Access Analyzer now supports Internet Protocol Version 6 (IPv6)\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/iam-access-analyzer-supports-ipv6/\\", \\"postDateTime\\": \\"03/05/2025\\", \\"absoluteDateTime\\": \\"2025-03-05T10:00:00-08:00\\"}, \\"feature9\\": {\\"headline\\": \\"Amazon RDS now provides visibility into IAM DB Authentication metrics and logs\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/amazon-rds-visibility-iam-db-authentication-metrics-logs\\", \\"postDateTime\\": \\"02/26/2025\\", \\"absoluteDateTime\\": \\"2025-02-26T17:00:00-05:00\\"}, \\"feature10\\": {\\"headline\\": \\"Amazon ECS adds support for additional IAM condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/amazon-ecs-additional-iam-condition-keys\\", \\"postDateTime\\": \\"02/26/2025\\", \\"absoluteDateTime\\": \\"2025-02-26T13:00:00-05:00\\"}, \\"feature11\\": {\\"headline\\": \\"AWS IAM announces support for encrypted SAML assertions \\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/aws-iam-encrypted-saml-assertions/\\", \\"postDateTime\\": \\"02/05/2025\\", \\"absoluteDateTime\\": \\"2025-02-05T10:00:00-08:00\\"}, \\"feature12\\": {\\"headline\\": \\"AWS CodeBuild announces support for project ARN and build ARN IAM condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/01/aws-codebuild-project-arn-build-arn-iam-condition-keys\\", \\"postDateTime\\": \\"01/28/2025\\", \\"absoluteDateTime\\": \\"2025-01-28T16:50:00-05:00\\"}, \\"feature13\\": {\\"headline\\": \\"IAM Roles Anywhere credential helper now supports TPM 2.0\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/12/iam-roles-anywhere-credential-helper-tpm-2-0\\", \\"postDateTime\\": \\"12/17/2024\\", \\"absoluteDateTime\\": \\"2024-12-17T14:50:00-05:00\\"}, \\"feature14\\": {\\"headline\\": \\"Announcing AWS STS support for ECDSA-based signatures of OIDC tokens\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/aws-sts-ecdsa-based-signatures-oidc-tokens\\", \\"postDateTime\\": \\"11/22/2024\\", \\"absoluteDateTime\\": \\"2024-11-22T15:15:00-05:00\\"}, \\"feature15\\": {\\"headline\\": \\"Amazon EKS simplifies providing IAM permissions to EKS add-ons\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/amazon-eks-iam-permissions-eks-add-ons\\", \\"postDateTime\\": \\"11/18/2024\\", \\"absoluteDateTime\\": \\"2024-11-18T17:00:00-05:00\\"}, \\"feature16\\": {\\"headline\\": \\"Centrally manage root access in AWS Identity and Access Management (IAM)\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/manage-root-access-aws-identity-access-management/\\", \\"postDateTime\\": \\"11/15/2024\\", \\"absoluteDateTime\\": \\"2024-11-15T10:00:00-08:00\\"}, \\"feature17\\": {\\"headline\\": \\"Customize scope of IAM Access Analyzer unused access analysis  \\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/customize-scope-iam-access-analyzer-unused-access-analysis/\\", \\"postDateTime\\": \\"11/14/2024\\", \\"absoluteDateTime\\": \\"2024-11-14T10:00:00-08:00\\"}, \\"feature18\\": {\\"headline\\": \\"Introducing resource control policies (RCPs) to centrally restrict access to AWS resources\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/resource-control-policies-restrict-access-aws-resources/\\", \\"postDateTime\\": \\"11/13/2024\\", \\"absoluteDateTime\\": \\"2024-11-13T10:00:00-08:00\\"}, \\"feature19\\": {\\"headline\\": \\"AWS IAM now supports PrivateLink in the AWS GovCloud (US) Regions\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/aws-iam-privatelink-govcloud-us-regions\\", \\"postDateTime\\": \\"11/08/2024\\", \\"absoluteDateTime\\": \\"2024-11-08T13:00:00-05:00\\"}, \\"feature20\\": {\\"headline\\": \\"Streamline automation of policy management workflows with service reference information\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/10/streamline-automation-policy-management-workflows-service-reference-information\\", \\"postDateTime\\": \\"10/10/2024\\", \\"absoluteDateTime\\": \\"2024-10-10T13:00:00-04:00\\"}, \\"feature21\\": {\\"headline\\": \\"Amazon S3 Access Grants introduce the ListCallerAccessGrants API\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/09/amazon-s3-access-grants-listcalleraccessgrants-api\\", \\"postDateTime\\": \\"09/05/2024\\", \\"absoluteDateTime\\": \\"2024-09-05T17:50:00-04:00\\"}, \\"feature22\\": {\\"headline\\": \\"AWS Identity and Access Management now supports AWS PrivateLink in all commercial Regions\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/08/aws-identity-access-management-aws-privatelink-regions/\\", \\"postDateTime\\": \\"08/22/2024\\", \\"absoluteDateTime\\": \\"2024-08-22T10:00:00-07:00\\"}, \\"feature23\\": {\\"headline\\": \\"AWS Identity and Access Management simplifies management of OpenID Connect identity providers\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/07/aws-identity-access-management-open-id-connect-identity-providers\\", \\"postDateTime\\": \\"07/12/2024\\", \\"absoluteDateTime\\": \\"2024-07-12T16:30:00-04:00\\"}, \\"feature24\\": {\\"headline\\": \\"AWS IAM Access Analyzer now offers policy checks for public and critical resource access\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/06/aws-iam-access-analyzer-policy-checks\\", \\"postDateTime\\": \\"06/11/2024\\", \\"absoluteDateTime\\": \\"2024-06-11T08:00:00-04:00\\"}}","today":" Today","yesterday":" Yesterday","daysAgo":" {day} days ago","weekAgo":" 1 week ago","weeksAgo":" {week} weeks ago","monthAgo":" 1 month ago","monthsAgo":" {month} months ago","yearAgo":" 1 year ago","header":"What\'s new","description":"Updates for features in IAM","viewAll":"View all","viewAllAria":"View all about What\'s New","more":"more","less":"less","moreAria":"Show more results","lessAria":"Show fewer results"},"mfaListWidget":{"mfaListLoadingText":"Loading","mfaListTableHeader":"Multi-factor authentication (MFA)","mfaListTableHeaderDescription":"As a best practice, use MFA to increase the security of your AWS environments. Signing in to MFA-protected accounts requires a user name, password, and an authentication code from an MFA device.","remove":"Remove","resync":"Resync","assignMfa":"Assign MFA","noDevice":"No MFA devices","noDeviceDescription":"Add an MFA device to increase the security of your AWS environment","deleteMFAModal":"Remove MFA device?","deleteMFAContent":"You won\'t be required to provide MFA codes when they sign in.","cancel":"Cancel","resyncMFATitle":"Resync MFA device","resyncMFAContent":"Fill in two consecutive codes from your MFA device to resynchronize it.","resyncInput1":"MFA code 1","resyncInput2":"MFA code 2"},"selectMFADevice":{"virtualDesc":"Authenticate using a code generated by an app installed on your mobile device or computer.","u2fDesc":"Authenticate using a code generated by touching a YubiKey or other supported U2F device.","hardwareDesc":"Authenticate using a code displayed on a hardware Time-based one-time password (TOTP) token.","authenticatorApp":"Authenticator app","u2fSecurityKey":"U2F security key","hardwareDevice":"Hardware TOTP token","selectDevice":"Select MFA device","selectDeviceSmall":"Select an MFA device to use, in addition to your username and password, whenever you need to authenticate.","cancel":"Cancel","next":"Next"},"setupMFADevice":{"pageTitle":"Activate multi-factor authentication (MFA)","setupTitle":"Set up your authenticator app","virtualDesc":"A virtual MFA device is an application running on your device that you can configure by scanning a QR code.","install":"Install a compatible application such as Google Authenticator, Duo Mobile, or Authy app on your mobile device or computer.","list":"See a list of compatible applications","show":"Show QR code","step2Text":"Open your authenticator app, choose <b>Show QR code</b> on this page, then use the app to scan the code. Alternatively, you can type a secret key. <show>Show secret key</show>","step3Text":"Type two consecutive MFA codes below","code1":"Enter a code from your virtual app below","code2":"Wait 30 seconds, and enter a second code entry.","cancel":"Cancel","previous":"Previous","addMFA":"Add MFA","hardwareTitle":"Set up hardware MFA device","hardwareDesc