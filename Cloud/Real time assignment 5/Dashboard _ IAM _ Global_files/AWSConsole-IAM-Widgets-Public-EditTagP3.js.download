ere {statement}?","removeStatementModal.body":"Rimuovere l\'istruzione?","errors":"Errori","warnings":"Avvisi","errorBoundaryHeader":"Errore durante il rendering dell\'editor di policy","actionList.listOnly":"Livello di accesso: elenco","actionList.readOnly":"Livello di accesso: lettura","actionList.readWrite":"Livello di accesso: lettura o scrittura","actionList.permissions":"Livello di accesso: autorizzazioni","actionList.tagging":"Livello di accesso: assegnazione di tag","controlPanel.noStatementSelected":"Seleziona un\'istruzione esistente nella policy o aggiungi una nuova istruzione.","serviceList.included":"Incluso","serviceList.available":"Disponibile","dataLoader.loaded":"Caricato","dataLoader.error":"Errore","dataLoader.typeEditor":"Editor","dataLoader.typeActions":"Operazioni","dataLoader.typeResources":"Risorse","dataLoader.typeConditions":"Condizioni","dataLoader.typeContextKeys":"Chiavi di contesto","dataLoader.unknown":"Sconosciuto","permissionModalPermissionsHeader":"Autorizzazioni","bidirectionalMessage":"La policy conteneva caratteri bidirezionali che non sono visibili e che sono stati rimossi per tuo conto. Le policy copiate da altre origini possono contenere caratteri che possono introdurre errori.","bidirectionalCloseButton":"Errore di silenzio","bidirectionalHeader":"La policy contiene caratteri bidirezionali","homoglyphMessage":"Alcuni caratteri utilizzati nella policy sono omoglifi e non rientrano nell\'intervallo di caratteri comuni. Verifica che i caratteri che utilizzi nei valori degli elementi della policy siano nello stesso formato dei caratteri utilizzati per le loro risorse. Ad esempio, utilizza lo stesso formato per il nome di una risorsa utilizzato per l\'ARN specificato per tale risorsa.","homoglyphCloseButton":"Avviso di silenzio","homoglyphHeader":"La policy contiene caratteri omoglifi","textUnder":"{size} di {limit} caratteri rimanenti","textAt":"È stato raggiunto il limite di {limit} caratteri","textOver":"Supera il limite di caratteri di {size}","bytesUnder":"{size} di {limit} KiB rimanenti","bytesAt":"È stato raggiunto il limite di {limit} KiB","bytesOver":"{size} byte superano il limite","bytesPopover":"La policy che supera il limite di {limit} KiB non può essere salvata. Ottimizza la policy per le dimensioni o crea una policy aggiuntiva con i caratteri in eccesso. ","info":"Informazioni","textPopover":"La policy che supera il limite di {limit} caratteri non può essere salvata. Ottimizza la policy per le dimensioni o crea una policy aggiuntiva con i caratteri in eccesso.","numberOfResultsFound":"{number} risultati trovati","close":"Chiudi","moreInformationForAction":"Ulteriori informazioni su {actionName}","policyContainsErrorSecurityWarningAndWarning":"La tua policy contiene {errorCount} errori, {securityWarningCount} avvisi di sicurezza e {warningCount} avvisi","policyContainsErrorAndSecurityWarning":"La tua policy contiene {errorCount} errori e {securityWarningCount} avvisi di sicurezza","policyContainsErrorAndWarning":"La tua policy contiene {errorCount} errori e {warningCount} avvisi","policyContainsSecurityWarningAndWarning":"La tua policy contiene {securityWarningCount} avvisi di sicurezza e {warningCount} avvisi","policyContainsError":"La tua policy contiene {errorCount} errori","policyContainsSecurityWarning":"La tua policy contiene {securityWarningCount} avvisi di sicurezza","policyContainsWarning":"La tua policy contiene {warningCount} avvisi","filterActions":"Cerca azioni","clearFilterActions":"Cancella il filtro e visualizza tutte le operazioni per il servizio","filterServices":"Cerca servizi","clearFilterServices":"Cancella il filtro e visualizza tutti i servizi disponibili","matches":"{count} corrispondenze","learnMoreAboutValidation":"Scopri di più sulla convalida delle policy","clearSearchLabel":"Cancella"},"whatsNewWidget":{"features.iam":"{\\"feature0\\": {\\"headline\\": \\"Amazon Bedrock introduces API keys for streamlined development\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/07/amazon-bedrock-api-keys-for-streamlined-development\\", \\"postDateTime\\": \\"07/08/2025\\", \\"absoluteDateTime\\": \\"2025-07-08T19:34:00Z\\"}, \\"feature1\\": {\\"headline\\": \\"AWS Service Reference Information now supports annotations for service actions\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/aws-service-reference-information-annotations/\\", \\"postDateTime\\": \\"06/26/2025\\", \\"absoluteDateTime\\": \\"2025-06-26T10:00:00-07:00\\"}, \\"feature2\\": {\\"headline\\": \\"AWS expands resource control policies (RCPs) support to two additional services\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/aws-resource-control-policies-additional-services\\", \\"postDateTime\\": \\"06/19/2025\\", \\"absoluteDateTime\\": \\"2025-06-19T13:00:00-04:00\\"}, \\"feature3\\": {\\"headline\\": \\"AWS IAM now enforces MFA for root users across all account types\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/aws-iam-mfa-root-users-across-all-account-types/\\", \\"postDateTime\\": \\"06/17/2025\\", \\"absoluteDateTime\\": \\"2025-06-17T10:00:00-04:00\\"}, \\"feature4\\": {\\"headline\\": \\"Amazon EKS Pod Identity simplifies the experience for cross-account access\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/06/amazon-eks-pod-identity-cross-account-access\\", \\"postDateTime\\": \\"06/12/2025\\", \\"absoluteDateTime\\": \\"2025-06-12T13:00:00-05:00\\"}, \\"feature5\\": {\\"headline\\": \\"Amazon EBS now supports additional resource-level permissions for copying EBS snapshots\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/04/amazon-ebs-additional-resource-level-permissions-copying-eb-snapshots\\", \\"postDateTime\\": \\"04/22/2025\\", \\"absoluteDateTime\\": \\"2025-04-22T15:15:00-04:00\\"}, \\"feature6\\": {\\"headline\\": \\"AWS Identity and Access Management now supports dual-stack (IPv4 and IPv6) environments\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/aws-identity-access-management-dual-stack-ipv4-ipv6-environments\\", \\"postDateTime\\": \\"03/28/2025\\", \\"absoluteDateTime\\": \\"2025-03-28T16:40:00-04:00\\"}, \\"feature7\\": {\\"headline\\": \\"AWS Service Reference Information now supports resources and condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/aws-service-reference-information-resources-condition-keys\\", \\"postDateTime\\": \\"03/13/2025\\", \\"absoluteDateTime\\": \\"2025-03-13T13:00:00-04:00\\"}, \\"feature8\\": {\\"headline\\": \\"IAM Access Analyzer now supports Internet Protocol Version 6 (IPv6)\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/03/iam-access-analyzer-supports-ipv6/\\", \\"postDateTime\\": \\"03/05/2025\\", \\"absoluteDateTime\\": \\"2025-03-05T10:00:00-08:00\\"}, \\"feature9\\": {\\"headline\\": \\"Amazon RDS now provides visibility into IAM DB Authentication metrics and logs\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/amazon-rds-visibility-iam-db-authentication-metrics-logs\\", \\"postDateTime\\": \\"02/26/2025\\", \\"absoluteDateTime\\": \\"2025-02-26T17:00:00-05:00\\"}, \\"feature10\\": {\\"headline\\": \\"Amazon ECS adds support for additional IAM condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/amazon-ecs-additional-iam-condition-keys\\", \\"postDateTime\\": \\"02/26/2025\\", \\"absoluteDateTime\\": \\"2025-02-26T13:00:00-05:00\\"}, \\"feature11\\": {\\"headline\\": \\"AWS IAM announces support for encrypted SAML assertions \\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/02/aws-iam-encrypted-saml-assertions/\\", \\"postDateTime\\": \\"02/05/2025\\", \\"absoluteDateTime\\": \\"2025-02-05T10:00:00-08:00\\"}, \\"feature12\\": {\\"headline\\": \\"AWS CodeBuild announces support for project ARN and build ARN IAM condition keys\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2025/01/aws-codebuild-project-arn-build-arn-iam-condition-keys\\", \\"postDateTime\\": \\"01/28/2025\\", \\"absoluteDateTime\\": \\"2025-01-28T16:50:00-05:00\\"}, \\"feature13\\": {\\"headline\\": \\"IAM Roles Anywhere credential helper now supports TPM 2.0\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/12/iam-roles-anywhere-credential-helper-tpm-2-0\\", \\"postDateTime\\": \\"12/17/2024\\", \\"absoluteDateTime\\": \\"2024-12-17T14:50:00-05:00\\"}, \\"feature14\\": {\\"headline\\": \\"Announcing AWS STS support for ECDSA-based signatures of OIDC tokens\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/aws-sts-ecdsa-based-signatures-oidc-tokens\\", \\"postDateTime\\": \\"11/22/2024\\", \\"absoluteDateTime\\": \\"2024-11-22T15:15:00-05:00\\"}, \\"feature15\\": {\\"headline\\": \\"Amazon EKS simplifies providing IAM permissions to EKS add-ons\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/amazon-eks-iam-permissions-eks-add-ons\\", \\"postDateTime\\": \\"11/18/2024\\", \\"absoluteDateTime\\": \\"2024-11-18T17:00:00-05:00\\"}, \\"feature16\\": {\\"headline\\": \\"Centrally manage root access in AWS Identity and Access Management (IAM)\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/manage-root-access-aws-identity-access-management/\\", \\"postDateTime\\": \\"11/15/2024\\", \\"absoluteDateTime\\": \\"2024-11-15T10:00:00-08:00\\"}, \\"feature17\\": {\\"headline\\": \\"Customize scope of IAM Access Analyzer unused access analysis  \\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/customize-scope-iam-access-analyzer-unused-access-analysis/\\", \\"postDateTime\\": \\"11/14/2024\\", \\"absoluteDateTime\\": \\"2024-11-14T10:00:00-08:00\\"}, \\"feature18\\": {\\"headline\\": \\"Introducing resource control policies (RCPs) to centrally restrict access to AWS resources\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/resource-control-policies-restrict-access-aws-resources/\\", \\"postDateTime\\": \\"11/13/2024\\", \\"absoluteDateTime\\": \\"2024-11-13T10:00:00-08:00\\"}, \\"feature19\\": {\\"headline\\": \\"AWS IAM now supports PrivateLink in the AWS GovCloud (US) Regions\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/11/aws-iam-privatelink-govcloud-us-regions\\", \\"postDateTime\\": \\"11/08/2024\\", \\"absoluteDateTime\\": \\"2024-11-08T13:00:00-05:00\\"}, \\"feature20\\": {\\"headline\\": \\"Streamline automation of policy management workflows with service reference information\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/10/streamline-automation-policy-management-workflows-service-reference-information\\", \\"postDateTime\\": \\"10/10/2024\\", \\"absoluteDateTime\\": \\"2024-10-10T13:00:00-04:00\\"}, \\"feature21\\": {\\"headline\\": \\"Amazon S3 Access Grants introduce the ListCallerAccessGrants API\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/09/amazon-s3-access-grants-listcalleraccessgrants-api\\", \\"postDateTime\\": \\"09/05/2024\\", \\"absoluteDateTime\\": \\"2024-09-05T17:50:00-04:00\\"}, \\"feature22\\": {\\"headline\\": \\"AWS Identity and Access Management now supports AWS PrivateLink in all commercial Regions\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/08/aws-identity-access-management-aws-privatelink-regions/\\", \\"postDateTime\\": \\"08/22/2024\\", \\"absoluteDateTime\\": \\"2024-08-22T10:00:00-07:00\\"}, \\"feature23\\": {\\"headline\\": \\"AWS Identity and Access Management simplifies management of OpenID Connect identity providers\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/07/aws-identity-access-management-open-id-connect-identity-providers\\", \\"postDateTime\\": \\"07/12/2024\\", \\"absoluteDateTime\\": \\"2024-07-12T16:30:00-04:00\\"}, \\"feature24\\": {\\"headline\\": \\"AWS IAM Access Analyzer now offers policy checks for public and critical resource access\\", \\"headlineUrl\\": \\"/about-aws/whats-new/2024/06/aws-iam-access-analyzer-policy-checks\\", \\"postDateTime\\": \\"06/11/2024\\", \\"absoluteDateTime\\": \\"2024-06-11T08:00:00-04:00\\"}}","today":" Oggi","yesterday":" Ieri","daysAgo":" {day} giorni fa","weekAgo":" 1 settimana fa","weeksAgo":" {week} settimane fa","monthAgo":" 1 mese fa","monthsAgo":" {month} mesi fa","yearAgo":