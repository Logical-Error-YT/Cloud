reate.path.label":"Path - optional","group.create.path.description":"Specify where you want to create this group.","group.create.path.hintText":"Maximum 512 characters. Begin and end with a '/'","group.create.path.errorText.maxLength.message":"Count exceeds 512 characters limit.","group.create.path.errorText.valid.message":"Valid path required.","group.create.createGroupSuccess":"{groupName} user group created. ","group.create.createGroupSuccess.addEntityFailure":"{groupName} user group created with a few errors. See error description below.","group.create.notification.group.loading.message":"Creating Group.","group.create.notification.group.error.message":"User group was not created. ","group.create.notification.button.viewGroup":"View group","group.create.userTable.Header":"Add users to the group - <i>Optional</i>","group.create.userTable.Header.cupcake":"Add IAM users to the IAM group - <i>Optional</i>","group.create.userTable.Description":"An IAM user is an entity that you create in AWS to represent the person or application that uses it to interact with AWS. A user can belong to up to {number} groups.","group.details.groupMembershipCountPopover.header":"User group memberships","groups.help.pageHeader":"User Groups","groups.help.pageBody":'<p>A user group is a collection of IAM users. User groups simplify permissions management by letting you grant, change, and remove permissions for multiple users at once. For example, you can create a user group named "Admins" and give that group administrative permissions. Any user in that group automatically has the permissions that are assigned to the group.</p>',"groups.help.linkText":"IAM user groups","group.leavePage.header":"Leave Page? ","group.leavePage.content":"Are you sure you want to leave the current page? The changes that you made won't be saved.","group.leavePage.leave":"Leave","group.leavePage.cancel":"Cancel","util.none":"None","util.never":"Never","util.delete":"Delete","util.edit":"Edit","util.attach":"Attach","util.detach":"Detach","util.arn":"ARN","util.search":"Search","util.and":"and","util.remove":"Remove","util.learnMoreText":"Learn more","util.retry":"Retry","util.refresh":"Refresh","group.create.tableHeadingForAttachPolicies":"Attach permissions policies - <i>Optional</i>","group.create.policy.exceedLimitation":"The selected policies exceeds the limitation","policy.all":"All","policyList.search":"Filter policies by property or policy name and press enter.","policy.customer.managed":"Customer managed","policy.aws.managed":"AWS managed","policy.aws.managed.job":"AWS managed - job function","policy.customer.inline":"Customer inline","policy.entity.popover.users":"Users","policy.entity.popover.groups":"Groups","policy.entity.popover.roles":"Roles","policy.entity.popover.attachedEntities":"Attached entities","policy.entity.popover.allAttachedEntities":"all attached entities","policy.list.pageTitle":"Policies","policy.table.name":"Policy name","policy.table.path":"Path","policy.table.attachments":"Attachments","policy.table.usedAs":"Used as","policy.table.type":"Type","policy.table.description":"Description","policy.table.createdTime":"Creation time","policy.table.editedTime":"Edited time ","policy.table.attachedEntities":"Attached entities","policy.table.numberOfPolicies":"{number} policies","policy.table.noMatch":"No match","policy.table.tableHeaderDescription":"A policy is an object in AWS that defines permissions.","policy.table.actionCreate":"Create policy","policy.table.permissionPolicy":"Permissions policy","policy.table.boundary":"Boundary","policy.used.permissions":"Used as permissions policy","policy.used.boundary":"Used as boundary","policy.delete.modal.header":"Delete {policyName}?","policy.delete.modal.description":"Delete {policyName} policy and all its versions permanently?","policy.delete.action.undone":"This action cannot be undone.","policy.delete.modal.attachedEntities.warning":"This policy will also be detached from {link}.","policy.delete.modal.